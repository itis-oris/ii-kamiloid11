Accept: application/json

GET http://localhost:8080/api/offers/999
Accept: application/json

POST http://localhost:8080/api/offers
Content-Type: application/json

{
  "title": "JavaScript Basics",
  "description": "Learn JavaScript from scratch: variables, functions, DOM manipulation, and modern ES6+ features.",
  "hoursPerSession": 1.5,
  "hourlyRate": 20.0,
  "rateCurrency": "EUR",
  "maxStudents": 4,
  "skillId": 1
}

### Update offer (requires authentication)
PUT http://localhost:8080/api/offers/1
Content-Type: application/json

{
  "title": "Python for Beginners - Updated",
  "description": "Updated description: Learn Python programming from scratch. Covers variables, loops, functions, OOP, and now includes data structures.",
  "hoursPerSession": 2.0,
  "hourlyRate": 30.0,
  "rateCurrency": "EUR",
  "maxStudents": 5,
  "skillId": 1
}

